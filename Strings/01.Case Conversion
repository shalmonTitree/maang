Time Limit: 1 sec
Memory: 256 MB

Description
You are given a string S in the CamelCase format. Your task is to convert this string into the snake_case format.

Examples of the CamelCase strings are as follows:
FedEx, algoZenith, WordPerfect.

Note that, in the CamelCase string, the first character may or may not be capitalized.

Examples of the snake_case strings are as follows:
fed _ex, algo_zenith, word_perfect.

Input Format
The first line contains one integer T, the number of test cases and then each of the following T lines contains one string S in CamelCase format.

Output Format
For each test case, print the snake_case output in a separate line.

Constraints

1 ≤ T ≤ 100
1 ≤ |S|, length of S ≤ 1000

Sample Input 1
6
HackerEarth
primeCheck
OddOrEven
random
getRandom
macOS

Sample Output 1
hacker_earth
prime_check
odd_or_even
random
get_random
mac_o_s



#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
#define endl "\n"   // optional, better to avoid redefining endl

void solve() {
    string s;
    cin>>s;
    string ans = "";
    ans += tolower(s[0]);
    for(int i = 1; i < s.size(); i++)
    {
        if(s[i] >= 'A' && s[i] <= 'Z')
        {
            ans += '_';
            ans += tolower(s[i]);
        }
        else
        {
            ans += tolower(s[i]);
        }
    }
    cout<<ans<<endl;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        solve();
    }

    return 0;
}
