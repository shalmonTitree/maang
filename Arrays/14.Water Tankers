#include <iostream>
#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
#define endl "\n" // optional, better to avoid redefining endl

void solve()
{
    int n;
    cin >> n;
    vector<ll> a(n);
    vector<ll> b(n);
    for (int i = 0; i < n; i++)
    {
        cin >> a[i];
    }
    for (int i = 0; i < n; i++)
    {
        cin >> b[i];
    }

    ll sum = accumulate(a.begin(),a.end(),0LL);
    sort(b.begin(),b.end(),greater<ll>());
    int cnt = 0;
    int idx = 0;
    while(sum>0)
    {
        sum -= b[idx];
        idx++;
        cnt++;
    }
    cout<<cnt<<endl;
    
}

int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--)
    {
        solve();
    }

    return 0;
}
