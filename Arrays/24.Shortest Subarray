Description
Given an array of N integers, find the length of the smallest sub-array that contains all the distinct elements of the array.

Input Format
The first line contains T, the number of test cases (1≤T≤10).
For each test case, the first line contains an integer N where 1≤N≤10^5.
The next line contains N space-separated integers A1,A2,...,AN where 0≤Ai≤10^5.

Output Format
For each test case print the length of the smallest sub-array that contains all the distinct elements of the array in a newline.

Constraints
1≤T≤10
1≤N≤10^5
0≤Ai≤10^5
Sum of N over all test cases does not exceed 10^5.

Sample Input 1
6
5
1 1 3 2 3
5
1 2 3 4 5
6
1 2 2 3 3 4
6
1 2 1 3 2 4
5
1 1 1 1 1
1
1

Sample Output 1
3
5
6
4
1
1

Note
For the first test case, the smallest sub-array containing all distinct elements is (1,3,2) of length 3.
For the second test case all elements are distinct so the smallest sub-array is the whole array of length 5.
For the third test case the smallest sub-array that contains all distinct elements is of length 6.



#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
#define endl "\n"   // optional, better to avoid redefining endl

void solve() {
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i = 0; i < n; i++)cin>>v[i];

    set<int>st(v.begin(),v.end());
    int len = st.size();

    int ans = INT_MAX;
    for(int i = 0; i < n; i++)
    {
        unordered_map<int,int>mp;
        for(int j = i; j < n;j++)
        {
            mp[v[j]]++;
            if(mp.size() == len)
            {
                ans = min(ans,j - i + 1);
            }

        }
    }
    if(ans == INT_MAX)
    {
        cout<<"0"<<endl;
    }
    else
    {
        cout<<ans<<endl;
    }
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        solve();
    }

    return 0;
}
