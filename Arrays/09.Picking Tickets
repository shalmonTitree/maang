#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
#define endl "\n"   // optional, better to avoid redefining endl

void solve() {
    int n;
    cin>>n;
    vector<ll>v(n);
    for(int i = 0; i < n; i++)cin>>v[i];
    int ans = 1;
    sort(v.begin(), v.end());

for (int i = 0; i < n; i++)
{
    int cnt = 1;

    for (int j = i + 1; j < n; j++)
    {
        if (v[j] - v[j - 1] <= 1)
            cnt++;
        else
            break;
    }

    ans = max(ans, cnt);
}

    cout<<ans<<endl;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        solve();
    }

    return 0;
}
