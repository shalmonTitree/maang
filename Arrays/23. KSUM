Description
Given an array A of size N, you have to find the longest sub-array such that the sum of all elements in the sub-array is divisible by K.

Input Format
The first line of each test case contains two integers N and K.
The second line contains N integers - the elements of the array A.

Output Format
For each test case, print the length of the longest sub-array satisfying the given condition in a new line.

Constraints
1 ≤ N ≤ 2 × 10^5
1 ≤ K ≤ 2 × 10^5
−10^9 ≤ A[i] ≤ 10^9

Sample Input 1
6 3
2 7 6 1 4 5

Sample Output 1
4

Sample Input 2
14 10
10 16 8 13 19 16 2 2 12 6 4 15 13 2

Sample Output 2
11

Note
For the first sample, the sub-array [7 6 1 4] has sum 18 which is divisible by 3 and its length is 4, which is the longest such segment.




//Bruteforce 
Time Complexity: O(n²)
Space Complexity: O(n)

#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
#define endl "\n"   // optional, better to avoid redefining endl

void solve() {
    ll n,k;
    cin>>n>>k;
    vector<ll>v(n);
    for(ll i = 0; i < n; i++)
    {
        cin>>v[i];
    }

    
    ll maxLength = 0;
    for(ll i = 0; i < n; i++)
    {
        ll sum = 0;
        for(ll j = i; j < n; j++)
        {
            sum += v[j];
            if(sum % k == 0)
            {
                maxLength = max(maxLength,j - i + 1);
            }
        }
    }
    cout<<maxLength<<endl;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}


//optimal
#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
#define endl "\n"   // optional, better to avoid redefining endl

void solve() {
    ll n,k;
    cin>>n>>k;
    vector<ll>v(n);
    for(ll i = 0; i < n; i++)
    {
        cin>>v[i];
    }

    
    ll maxLength = 0;
    unordered_map<ll,ll>mp;
    mp[0] = -1;
    ll sum = 0;

    for(ll i = 0; i < n; i++)
    {
        sum += v[i];
        ll rem = ((sum % k) + k) % k;
        if(mp.find(rem) != mp.end())
        {
            maxLength = max(maxLength, i - mp[rem]);
        }
       
        if(mp.find(rem) == mp.end())
        {
            mp[rem] = i;
        }

    }
    cout<<maxLength<<endl;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}
