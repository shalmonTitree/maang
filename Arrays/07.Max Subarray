void solve() {
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i = 0; i < n; i++)
    {
        cin>>v[i];
    }
    vector<int>ans;
    for(int i = 0; i < n; i++)
    {
        vector<int>sub;
        for(int j = i; j < n; j++)
        {
            sub.push_back(v[j]);
            int mx = *max_element(sub.begin(),sub.end());
            ans.push_back(mx);
        }
    }
    sort(ans.begin(),ans.end());
    for(auto it : ans)
    {
        cout<<it<<" ";
    }
    cout<<endl;
}

int main() {
    ios::sync_with_stdio(false);
