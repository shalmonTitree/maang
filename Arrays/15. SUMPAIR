Description
Given two integer arrays A and B, you have to implement a data structure that supports queries of two types:

* add a positive integer to an element of a given index in the array B.
* count the number of pairs (i, j) such that A[i] + B[j] equals a given value total.

Input Format
The first line contains three integers n, m, and q - the sizes of arrays A and B, and the number of queries, respectively.

The second line contains n space-separated integers A[0], A[1], …, A[n−1].

The third line contains m space-separated integers B[0], B[1], …, B[m−1].

Each of the next q lines contains a query in one of the following two formats:

* add x y - add integer y to B[x] (indices are 0-indexed).
* count total - output the number of pairs (i, j) such that A[i] + B[j] = total.

Output Format
For each count query, output the number of pairs satisfying the condition.

Constraints
1 ≤ n ≤ 1000
1 ≤ m ≤ 10⁵
1 ≤ A[i], B[i] ≤ 10⁵
0 ≤ x < m
1 ≤ y ≤ 10⁵
1 ≤ total ≤ 2 × 10⁹

At most 1000 calls are made to add and count each.

Sample Input 1
3 3 3
4 5 6
1 2 3
count 7
add 0 2
count 9

Sample Output 1
3
2

Note

Initially,
A = [4, 5, 6],
B = [1, 2, 3].

First query: count 7
Possible pairs are:

(0, 2):
A[0] + B[2] = 4 + 3 = 7

(1, 1):
5 + 2 = 7

(2, 0):
6 + 1 = 7

So, the answer is 3.

Second query: add 0 2
Update B[0] to B[0] + 2 = 1 + 2 = 3, now B becomes [3, 2, 3].

Third query: count 9
Possible pairs are:

(2, 0):
6 + 3 = 9

(2, 2):
6 + 3 = 9

So, the answer is 2.



//bruteforce

#include <iostream>
#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
#define endl "\n" // optional, better to avoid redefining endl

void solve()
{
    int n,m,q;
    cin >> n>>m>>q;
    vector<ll> a(n);
    vector<ll> b(m);
    for (int i = 0; i < n; i++)
    {
        cin >> a[i];
    }
    for (int i = 0; i < m; i++)
    {
        cin >> b[i];
    }
    while(q--)
    {
        string s;
        cin>>s;
        if(s == "add")
        {
            int ax,by;
            cin>>ax>>by;
             b[ax] += by;
        }
        else if(s == "count")
        {
            ll target;
            cin>>target;
            int cnt = 0;
            for(int i = 0; i < n; i++)
            {
                for(int j = 0; j < m; j++)
                {
                    if(a[i] + b[j] == target)
                    {
                        cnt++;
                    }
                }
            }
            cout<<cnt<<endl;
        }
    }

    
}

int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--)
    {
        solve();
    }

    return 0;
}


//better




#include <bits/stdc++.h>
using namespace std;
typedef long long ll;

class FindPairswithSum
{
public:
     vector<int> a, b;
    int n, m;

    unordered_map<ll,ll> mp;
    FindPairswithSum(vector<int> &A, vector<int> &B)
    {
         a = A;
        b = B;

        n = a.size();
        m = b.size();

        for(int i = 0; i < m; i++)
        {
            mp[b[i]]++;
        }
    }

    void add(int index, int val)
    {
           
            mp[b[index]]--;
             b[index] += val;
             mp[b[index]]++;
    }

    int count(int total)
    {
        ll cnt = 0;
            for(int i = 0; i < n; i++)
            {
                ll t = total - a[i];
                if(mp.find(t) != mp.end())
                {
                    cnt+= mp[t];
                }
            }
            return cnt;
    }
};


int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(0);
    cout.tie(0);

    int n, m, q;
    cin >> n >> m >> q;

    vector<int> A(n), B(m);

    for (auto &i : A)
    {
        cin >> i;
    }

    for (auto &i : B)
    {
        cin >> i;
    }

    FindPairswithSum *obj = new FindPairswithSum(A, B);

    for (int i = 0; i < q; i++)
    {
        string op;
        cin >> op;
        if (op == "add")
        {
            int index, val;
            cin >> index >> val;
            obj->add(index, val);
        }
        else
        {
            int total;
            cin >> total;
            cout << obj->count(total) << '\n';
        }
    }

    return 0;
}


