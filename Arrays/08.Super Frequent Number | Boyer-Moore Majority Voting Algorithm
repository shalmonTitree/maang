//bruteforce  TLE 
#include <bits/stdc++.h>
using namespace std;

int SuperFrequentElement(vector<int> &v)
{
    int len = v.size();
    int ans = -1;
    
    for(int i = 0; i < len; i++)
    {   int cnt = 0;
        for(int j = 0; j < len; j++)
        {
            if(v[i] == v[j])
            {
                cnt++;
            }
        }
        if(cnt >= floor(len/2))
        {
            return v[i];
        }
    }
    return 0;
}


int main()
{
    ios_base::sync_with_stdio(NULL);
    cin.tie(NULL);
    cout.tie(NULL);
    int n;
    cin >> n;
    vector<int> v(n);
    for (auto &i : v)
        cin >> i;

    cout << SuperFrequentElement(v) << "\n";
}



