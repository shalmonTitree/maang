//optimal  | Boyer-Moore Majority Voting Algorithm

#include <bits/stdc++.h>
using namespace std;


int SuperFrequentElement(vector<int> &v)
{
    int ele = 0;
    int cnt = 0;
    int idx = -1;
    for(int i = 0; i < v.size(); i++)
    {
        if(cnt == 0)
        {
            ele = v[i];
            cnt = 1;
        }

        if(ele == v[i])
        {
            cnt++;
        }
        else
        {
            cnt--;
        }
    }
    
    return ele;
}


