//bruteforce
#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
#define endl "\n"   // optional, better to avoid redefining endl

void solve() {
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i = 0; i < n; i++)
    {
        cin>>v[i];
    }
    int sum = INT_MAX;
    for(int i = 0; i < n; i++)
    {
        for(int j = i + 1; j < n; j++)
        {
            sum = min(sum,v[i] + v[j] + j - i);
        }
    }
    cout<<sum<<endl;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        solve();
    }

    return 0;
}
