//bruteforce tle 
#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
#define endl "\n"   // optional, better to avoid redefining endl

void solve() {
    int n,q;
    cin>>n>>q;
    vector<ll>v(n);
    for(int i = 0; i < n; i++)
    {
        cin>>v[i];
    }
    while(q--)
    {
        int l,r;
        cin>>l>>r;
        l--;
        r--;
        ll sum = 0;
        for(int i = l; i <= r; i++)
        {
            sum += v[i];
        }
        cout<<sum<<endl;
    }
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        solve();
    }

    return 0;
}

//optimal using perefix sum
#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
#define endl "\n"   // optional, better to avoid redefining endl

void solve() {
    int n,q;
    cin>>n>>q;
    vector<ll>prefix(n+1,0);
  
    for(int i = 1; i <= n; i++)
    {
        ll v;
        cin>>v;
        prefix[i] = prefix[i-1] + v;

    }
    while(q--)
    {
        int l,r;
        cin>>l>>r;
    
        
        cout<<(prefix[r] - prefix[l-1])<<endl;
    }
}


int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        solve();
    }

    return 0;
}
