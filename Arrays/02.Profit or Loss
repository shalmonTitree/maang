Time Limit: 1 sec
Memory: 256 MB

Description

Maxwell owns a stationery shop. At the end of every month, he notes his profits (or losses) for the month in a notebook. Profits are noted as positive numbers, losses are noted as negative numbers, and the rest are noted as zeros.

Maxwell has asked you to write a program to rearrange the profits and losses such that all the losses are shown at the beginning, and all the profits are shown at the end. The order of profit or loss in relation to other values of the same sign should not be changed.

Input Format

The first line of the input contains one integer T - the number of test cases.

For each test case:

The first line contains an integer N - total number of months.

The second line contains N integers, where the ith integer represents the profit (or loss) of the ith month.

Output Format

For each test case, in a single line, output N integers in arranged manner with the relative positions of the same signed numbers unchanged.

Constraints

1 ≤ T ≤ 100
1 ≤ N ≤ 1500
-10^3 ≤ A[i] ≤ 10^3

The sum of N over all test cases does not exceed 1500.

Sample Input 1

2
6
2 0 7 -6 3 -5
4
-1 -1 3 0

Sample Output 1

-6 -5 0 2 7 3
-1 -1 0 3

Note

For the first test case:

Losses are -6 and -5, and the profits are 2, 7 and 3.
Rearranging gives:

[-6, -5, 0, 2, 7, 3]

For the second test case:

Losses are -1 and -1, and the profit is 3.
Rearranging gives:

[-1, -1, 0, 3]


#include <bits/stdc++.h>
using namespace std;

void solve() {
    int n;
    cin >> n;

    vector<int> v(n), ans;

    for (int i = 0; i < n; i++)
        cin >> v[i];

    // Negative numbers
    for (int x : v)
        if (x < 0)
            ans.push_back(x);

    // Zeros
    for (int x : v)
        if (x == 0)
            ans.push_back(x);

    // Positive numbers
    for (int x : v)
        if (x > 0)
            ans.push_back(x);

    for (int x : ans)
        cout << x << " ";
    cout << "\n";
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;
    while (t--) {
        solve();
    }

    return 0;
}
