Time Limit: 1 sec
Memory: 256 MB

Description
You are hosting a party and have invited N guests. The guests may or may not know each other. You are expecting a famous celebrity to show up. A celebrity is a person who doesn`t know anyone else but everyone else knows him. Find the celebrity if present.

Try to solve it in O(N) time with constant extra space.

Input Format
The first line of each test case contains N - the number of guests attending the party.
The next N lines contain N integers. The jth integer of the ith line is 1 if the ith person knows the jth person, otherwise it is 0. (The ith integer of the ith line is always 0.)

Output Format
Print index of the person who is a celebrity if present, else print -1.

Constraints
2≤N≤1000

Samples

Sample Input 1
3
0 1 0
0 0 0
0 1 0

Sample Output 1
2

Sample Input 2
2
0 1
1 0

Sample Output 2
-1

Sample Input 1
3
0 1 0
0 0 0
0 1 0

Sample Output 1
2

Sample Input 2
2
0 1
1 0

Sample Output 2
-1

Note
In Sample Input 1, the 2nd person does not know anyone and both the 1st and 3rd persons know the 2nd person, hence the celebrity is person 2.

In Sample Input 2, both guests know each other, hence there is no celebrity and the output is -1.

#include <bits/stdc++.h>
using namespace std;


int FindCeleb(vector<vector<int>> &a)
{
    // Complete the solution
    int n = a.size();
  
    int cnt = 0;
    for(int i = 0; i < n; i++)
    {
        bool ft = false;
        for(int j = 0; j < n; j++)
        {
            if(a[i][j] == 1)
            {
                ft = true;
                break;
            }
        }

        if(ft)
        {
            continue;
        }

        bool ff = true;
        for(int j = 0; j < n; j++)
        {
            if(i != j && a[j][i] == 0)
            {
                ff = false;
                break;
            }
        }
        if(ff)
        {
            return i+1;
        }
        
    }
    
    return -1;
}


int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    cout.tie(NULL);

    int n;
    cin >> n;

    vector<vector<int>> a(n, vector<int>(n));

    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            cin >> a[i][j];

    cout << FindCeleb(a) << '\n';
}
